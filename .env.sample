# Supabase Postgres Connection
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Speechmatics Transcription API Key (Required for audio processing)
SPEECHMATICS_API_KEY=your-speechmatics-api-key

# OpenAI-Compatible API Configuration (Required for AI responses)
LLM_BASE_URL=https://api.example.com/v1
LLM_API_KEY=your-llm-api-key
LLM_MODEL=your-llm-model-name

# Fallback LLM / Alternative API Keys
# NVIDIA_API_KEY=your-nvidia-api-key
# NVIDIA_MODEL=meta/llama-3.1-70b-instruct
# ANTHROPIC_API_KEY=your-anthropic-key
# GEMINI_API_KEY=your-gemini-key
# GEMINI_MODEL=gemini-2.0-flash

# LLM Gating & Limits
MIN_CONFIDENCE_FOR_GEMINI=0.99
MAX_GEMINI_CALLS_PER_SESSION=10

# WhatsApp Cloud API Credentials
WHATSAPP_PHONE_NUMBER_ID=your-whatsapp-phone-id
WHATSAPP_ACCESS_TOKEN=your-whatsapp-access-token
WHATSAPP_VERIFY_TOKEN=your-custom-webhook-verify-token

# Server Port
PORT=3000
